# =============================================================
# SkyRoute Car Rental — Environment Configuration
# =============================================================
#
# INSTRUCTIONS FOR FIRST-TIME SETUP:
# 1. Copy this file and name the copy exactly: .env
#    Windows Command Prompt:  copy .env.example .env
#    Windows PowerShell:      Copy-Item .env.example .env
#
# 2. Open .env in Notepad and replace YOUR_MYSQL_PASSWORD_HERE
#    with the password you set when installing MySQL.
#
# 3. Save .env — that is the only file you need to change!
#
# SECURITY NOTE: .env is in .gitignore and will never be
# uploaded to GitHub. Your password stays on your machine only.
# =============================================================

# MySQL Database Connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=CarRentalDb
DB_USER=root
DB_PASSWORD=YOUR_MYSQL_PASSWORD_HERE

# API Server (port the backend listens on)
API_PORT=5000
